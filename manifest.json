{
  "manifest_version": 3,
  "name": "Focus Intent",
  "version": "1.0.0",
  "description": "Stay focused through intentional browsing—task-aware sessions, gentle friction, and recovery—not brute-force blocking.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Focus Intent",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/main.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["http://*/*", "https://*/*"]
}
